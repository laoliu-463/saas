        <!-- GET /users/assignable -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="可分配用户列表" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
