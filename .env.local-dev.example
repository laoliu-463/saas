# 本地热更新开发（复制为仓库根目录 `.env` 或 `.env.local-dev` 后使用）
# 启动：PowerShell  scripts/dev-hot-reload.ps1
#        或分别执行 npm run dev:frontend / npm run dev:backend

SPRING_PROFILES_ACTIVE=local-mock
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_POLL_INTERVAL=3s
SPRING_DEVTOOLS_QUIET_PERIOD=2s

DB_HOST=localhost
DB_PORT=5432
DB_NAME=colonel_saas
DB_USER=saas
DB_PASSWORD=saas123
REDIS_HOST=localhost
REDIS_PORT=6379

# 前端 Vite（HMR 默认开启，无需轮询）
VITE_DEV_PORT=3000
VITE_PROXY_TARGET=http://localhost:8080

# 仅在 WSL/网络盘等监听异常时再打开（会增加 CPU）
# CHOKIDAR_USEPOLLING=false
# VITE_FORCE_POLLING=false
