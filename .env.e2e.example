E2E_BASE_URL=http://localhost:3000
E2E_HEADLESS=false
E2E_VISUAL_ASSERT=false

# real-pre 抖店联调（仅 08 用例）：设 E2E_REAL_PRE=true，并配好前后端地址；日常联调可忽略
# E2E_REAL_PRE=true
# E2E_BASE_URL=http://localhost:3001
# E2E_BACKEND_URL=http://localhost:8081

E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=admin123

E2E_BIZ_LEADER_USERNAME=biz_leader
E2E_BIZ_LEADER_PASSWORD=admin123

E2E_CHANNEL_LEADER_USERNAME=channel_leader
E2E_CHANNEL_LEADER_PASSWORD=admin123

E2E_CHANNEL_USERNAME=channel_leader
E2E_CHANNEL_PASSWORD=admin123

E2E_CHANNEL_STAFF_USERNAME=channel_staff
E2E_CHANNEL_STAFF_PASSWORD=admin123

E2E_OPS_USERNAME=ops_staff
E2E_OPS_PASSWORD=admin123

E2E_PRODUCT_KEYWORD=
E2E_ACTIVITY_KEYWORD=
E2E_ORDER_KEYWORD=
E2E_SAMPLE_KEYWORD=

