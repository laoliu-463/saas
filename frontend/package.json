{
  "name": "frontend-tmp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "typecheck:test": "vue-tsc -b tsconfig.vitest.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "xlsx": "npm:@e965/xlsx@^0.20.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.9.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.7"
  }
}
