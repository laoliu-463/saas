# ============================================================
# Development image: Vite dev server with hot-reload
# Usage: docker compose up frontend
#   - Mount frontend/src as volume for source code HMR
#   - Vite HMR updates in-browser without page refresh
# ============================================================
FROM node:20-alpine

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy package files first (for dependency cache)
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install --frozen-lockfile \
    && cp -a node_modules /opt/frontend-node_modules \
    && sha256sum pnpm-lock.yaml | awk '{print $1}' > /opt/frontend-node_modules.lock.sha256

COPY docker-entrypoint.dev.sh /usr/local/bin/frontend-dev-entrypoint
RUN chmod +x /usr/local/bin/frontend-dev-entrypoint

# Copy source code (will be volume-mounted in compose for hot-reload)
COPY . .

# Expose Vite default port
EXPOSE 3000

# Keep the mounted node_modules volume in sync with package changes, then start Vite.
CMD ["frontend-dev-entrypoint"]
