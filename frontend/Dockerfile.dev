# ============================================================
# Development image: Vite dev server with hot-reload
# Usage: docker compose up frontend
#   - Mount frontend/src as volume for source code HMR
#   - Vite HMR updates in-browser without page refresh
# ============================================================
FROM node:20-alpine

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy package files first (for dependency cache)
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Copy source code (will be volume-mounted in compose for hot-reload)
COPY . .

# Expose Vite default port
EXPOSE 3000

# Start Vite dev server (HMR enabled by default)
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
