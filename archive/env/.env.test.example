# Docker Compose — isolated TEST stack (project: saas-active)
# Copy to `.env.test` for scripts/start-test.ps1

SAAS_ENV_SLUG=test
SPRING_PROFILES_ACTIVE=test

DB_NAME=saas_test
DB_USER=saas
DB_PASSWORD=change-me
POSTGRES_HOST_PORT=5432

REDIS_HOST_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1

BACKEND_HOST_PORT=8080
BACKEND_DEBUG_HOST_PORT=5005
FRONTEND_HOST_PORT=3000

JWT_SECRET=replace-with-random-64-char-secret

DOUYIN_BASE_URL=https://openapi-fxg.jinritemai.com
DOUYIN_TEST_ENABLED=true
DOUYIN_REAL_UPSTREAM_MODE=live
DOUYIN_TOKEN_AUTO_REFRESH_ENABLED=false

APP_TEST_ENABLED=true
APP_TEST_SEED_ON_STARTUP=true
APP_TEST_DOUYIN_ENABLED=false
APP_TEST_PROMOTION_ENABLED=false
APP_TEST_ORDER_ENABLED=false
APP_TEST_TALENT_ENABLED=false
APP_TEST_LOGISTICS_ENABLED=false

ORDER_SYNC_ENABLED=false

TALENT_ENRICH_MODE=test
TALENT_PUBLIC_PAGE_CRAWL_ENABLED=false

VITE_ENV_LABEL=TEST
APP_ENV_LABEL=TEST
