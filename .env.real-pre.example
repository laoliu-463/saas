# SAAS real-pre environment example.
# Copy this file to .env.real-pre on the server, then fill all MUST_CHANGE values.
# Do not commit .env.real-pre or real credentials.
#
# 验收前运行 scripts/real-pre-startup-check.sh 自检基线开关。
# 完整开关契约见 docs/deploy/08-real-pre参数开关契约.md。

COMPOSE_PROJECT_NAME=saas-active
# When deploying with /opt/saas/env/.env.real-pre, scripts export this as an absolute path.
REAL_PRE_ENV_FILE=.env.real-pre
# 仅供本地 docker-compose.real-pre.yml 开发构建；远端 Jenkins 发布不读取该变量。
IMAGE_TAG=local-real-pre

SAAS_ENV_SLUG=real-pre
SPRING_PROFILES_ACTIVE=real-pre
APP_ENV_LABEL=REAL-PRE

# 单通道 CD 会校验 flyway_schema_history。完成数据库迁移演练前保持 false；
# 正式启用后，运行版本接口必须返回发布清单中的 Flyway 版本，否则部署失败。
FLYWAY_ENABLED=false

# PostgreSQL runs inside the compose network. Do not expose 5432 on the public host.
DB_HOST=postgres-real-pre
DB_PORT=5432
DB_NAME=saas_real_pre
DB_USER=saas
DB_PASSWORD=__FILL_ME_DB_PASSWORD__
ADMIN_PASSWORD=__FILL_ME_INITIAL_ADMIN_PASSWORD__

# Redis runs inside the compose network. REDIS_PASSWORD is required by the real-pre startup guard.
REDIS_HOST=redis-real-pre
REDIS_PORT=6379
REDIS_PASSWORD=__FILL_ME_REDIS_PASSWORD__
REDIS_DATABASE=0

# Public service ports.
BACKEND_HOST_PORT=8081
FRONTEND_HOST_PORT=3001
FRONTEND_DOMAIN=_
BACKEND_UPSTREAM=backend-real-pre:8080
# Complete domain deployment should use the Baota/Nginx HTTPS origin.
# Direct http://SERVER_IP:3001 is only for temporary port-level debugging before OAuth.
CORS_ALLOWED_ORIGIN_PATTERNS=https://real-pre.YOUR_DOMAIN

# MUST_CHANGE: use a random value of at least 32 characters.
JWT_SECRET=__FILL_ME_RANDOM_64_CHAR_SECRET__

# Douyin / Doudian real-pre credentials. MUST_CHANGE before real upstream validation.
# ---------------------------------------------------------------------------
# 抖店真实凭证（MUST_CHANGE）
# ---------------------------------------------------------------------------
DOUYIN_BASE_URL=https://openapi-fxg.jinritemai.com
DOUYIN_APP_ID=MUST_CHANGE_DOUYIN_APP_ID
DOUYIN_CLIENT_KEY=MUST_CHANGE_DOUYIN_CLIENT_KEY
DOUYIN_CLIENT_SECRET=__FILL_ME_DOUYIN_CLIENT_SECRET__
DOUYIN_SANDBOX=false
DOUYIN_OAUTH_AUTHORIZE_URL=https://op.jinritemai.com/oauth2/authorize
DOUYIN_OAUTH_REDIRECT_URI=https://real-pre.YOUR_DOMAIN/api/douyin/oauth/callback
DOUYIN_OAUTH_FRONTEND_SUCCESS_URL=https://real-pre.YOUR_DOMAIN/system/douyin?oauth=success
DOUYIN_OAUTH_FRONTEND_FAILURE_URL=https://real-pre.YOUR_DOMAIN/system/douyin?oauth=failed
DOUYIN_OAUTH_STATE_TTL_MINUTES=10
# ---------------------------------------------------------------------------
# 真实联调基线开关（real-pre 启动自检必须全部满足）
# 详见 docs/deploy/08-real-pre参数开关契约.md
# ---------------------------------------------------------------------------
DOUYIN_TEST_ENABLED=false
DOUYIN_REAL_UPSTREAM_MODE=live

# ---------------------------------------------------------------------------
# 真实推广写双开关（real-pre 默认开启）
# real-pre 是真实上游 / 生产形态环境，涉及上游的读、同步、刷新、回调和写入开关默认开启。
# 若因上游冻结、风控或人工暂停需要关闭，必须同步记录影响范围和恢复计划。
# ---------------------------------------------------------------------------
DOUYIN_REAL_PROMOTION_WRITE_ENABLED=true
ALLOW_REAL_PROMOTION_WRITE=true
DOUYIN_CONNECT_TIMEOUT=3s
DOUYIN_READ_TIMEOUT=5s
DOUYIN_TOKEN_REFRESH_THRESHOLD_SECONDS=300
DOUYIN_TOKEN_REDIS_LOCK_MINUTES=5
DOUYIN_TOKEN_AUTO_REFRESH_ENABLED=true
DOUYIN_TOKEN_AUTO_REFRESH_CRON=0 */10 * * * ?
DOUYIN_WEBHOOK_VERIFY_SIGN=true

ORDER_SYNC_ENABLED=true
PRODUCT_ACTIVITY_SYNC_ENABLED=true
PRODUCT_ACTIVITY_SYNC_CRON=0 */5 * * * ?
PRODUCT_ACTIVITY_SYNC_PARALLELISM=2

# ---------------------------------------------------------------------------
# 达人数据采集（real-pre guard 禁止 crawler 模式）
# ---------------------------------------------------------------------------
TALENT_ENRICH_MODE=real
TALENT_COLLECT_MODE=api
TALENT_COLLECT_API_ENABLED=true
TALENT_REFRESH_ENABLED=true
# real-pre guard forbids public crawler mode. Keep these false unless the guard and compliance decision are changed.
TALENT_PUBLIC_PAGE_CRAWL_ENABLED=false
TALENT_PROFILE_PUBLIC_WEB_ENABLED=false
TALENT_PROFILE_HTTP_ENABLED=false
TALENT_PROFILE_HTTP_ENDPOINT=
TALENT_PROFILE_HTTP_METHOD=GET
TALENT_PROFILE_HTTP_TOKEN=
TALENT_PROFILE_HTTP_AUTHORIZATION=

# ---------------------------------------------------------------------------
# 应用测试模式（real-pre 基线：必须关闭）
# ---------------------------------------------------------------------------
APP_TEST_ENABLED=false
APP_TEST_SEED_ON_STARTUP=false

# Logistics real-pre gateway. Fill real values only when this integration is enabled.
# If LOGISTICS_KD100_SUBSCRIBE_ENABLED=true, callback URL should be:
# https://real-pre.YOUR_DOMAIN/api/public/logistics/kuaidi100/callback
LOGISTICS_PROVIDER=kuaidi100
LOGISTICS_KD100_ENABLED=true
LOGISTICS_KD100_SUBSCRIBE_ENABLED=true
LOGISTICS_KD100_CUSTOMER=MUST_CHANGE_LOGISTICS_KD100_CUSTOMER
LOGISTICS_KD100_KEY=MUST_CHANGE_LOGISTICS_KD100_KEY
LOGISTICS_KD100_ENDPOINT=https://poll.kuaidi100.com/poll/query.do
LOGISTICS_KD100_SUBSCRIBE_ENDPOINT=https://poll.kuaidi100.com/poll
LOGISTICS_KD100_CALLBACK_URL=https://real-pre.YOUR_DOMAIN/api/public/logistics/kuaidi100/callback
LOGISTICS_KD100_CALLBACK_SALT=MUST_CHANGE_LOGISTICS_KD100_CALLBACK_SALT
LOGISTICS_KD100_RESULT_V2=4
LOGISTICS_KD100_SANDBOX_ENABLED=false
LOGISTICS_SYNC_ENABLED=true

# real-pre guard currently forbids exclusive.enabled=true. Enabling it changes attribution priority.
EXCLUSIVE_ENABLED=false
VITE_ENV_LABEL=REAL-PRE
