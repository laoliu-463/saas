<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="org.hibernate.validator.internal.util.Version" level="WARN"/>
    <logger name="org.springframework.mock.web" level="WARN"/>
    <logger name="org.springframework.test.web.servlet" level="WARN"/>
    <logger name="org.springframework.test.context.support.AnnotationConfigContextLoaderUtils" level="WARN"/>
    <logger name="org.springframework.boot.test.context.SpringBootTestContextBootstrapper" level="WARN"/>
    <logger name="org.springframework.boot.devtools.restart.RestartApplicationListener" level="WARN"/>
    <logger name="org.springframework.boot.actuate.endpoint.web.EndpointLinksResolver" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.springframework.data.repository.config" level="WARN"/>
    <logger name="com.colonel.saas.controller.DouyinWebhookController" level="ERROR"/>
    <logger name="com.colonel.saas.crawler.CrawlerScheduler" level="OFF"/>
    <logger name="com.colonel.saas.crawler.DouyinTalentCrawler" level="ERROR"/>
    <logger name="com.colonel.saas.douyin.DouyinApiClient" level="OFF"/>
    <logger name="com.colonel.saas.job.TalentWeeklyRefreshJob" level="OFF"/>
    <logger name="com.colonel.saas.job.ExclusiveEvaluateJob" level="OFF"/>
    <logger name="com.colonel.saas.job.SampleLifecycleJob" level="OFF"/>
    <logger name="com.colonel.saas.job.OrderSyncJob" level="OFF"/>
    <logger name="com.colonel.saas.job.DouyinTokenRefreshJob" level="ERROR"/>
    <logger name="com.colonel.saas.douyin.DouyinTokenService" level="OFF"/>
    <logger name="com.colonel.saas.service.CrawlerTalentInfoService" level="WARN"/>
    <logger name="com.colonel.saas.service.ExclusiveMerchantService" level="WARN"/>
    <logger name="com.colonel.saas.service.ExclusiveTalentService" level="WARN"/>
    <logger name="com.colonel.saas.service.OrderSyncService" level="ERROR"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
