# ============================================================
# Test runtime image — does NOT compile.
# Host compiles:  mvn package -DskipTests
# Container only starts:  java -jar target/colonel-saas.jar
# ============================================================
FROM eclipse-temurin:17-jre

WORKDIR /app

RUN mkdir -p /app/target

ENTRYPOINT ["sh", "/app/scripts/run-jar.sh"]

EXPOSE 8080 5005
