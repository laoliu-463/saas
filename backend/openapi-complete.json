  "components": {
    "schemas": {
      "LoginRequest": {
        "required": ["username", "password"],
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "登录用户名",
            "example": "admin",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "admin123",
            "maxLength": 128
          }
        },
        "description": "登录请求参数"
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT 访问令牌"
          },
          "tokenType": {
            "type": "string",
            "description": "令牌类型",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "description": "令牌有效期（秒）",
            "format": "int64",
            "example": 7200
          },
          "userId": {
            "type": "string",
            "description": "用户 ID",
            "format": "uuid"
          },
          "deptId": {
            "type": "string",
            "description": "部门 ID",
            "format": "uuid"
          },
          "dataScope": {
            "type": "integer",
            "description": "数据范围，1=本人，2=本组，3=全部",
            "format": "int32",
            "example": 3
          },
          "roleCodes": {
            "type": "array",
            "description": "角色编码列表",
            "items": {
              "type": "string"
            }
          },
          "username": {
            "type": "string",
            "description": "用户名",
            "example": "admin"
          },
          "realName": {
            "type": "string",
            "description": "真实姓名",
            "example": "系统管理员"
          }
        },
        "description": "登录响应数据"
      },
      "SysUserCreateRequest": {
        "required": ["username", "password", "realName", "roleIds"],
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "example": "zhangsan",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "登录密码",
            "example": "Passw0rd!",
            "minLength": 6,
            "maxLength": 128
          },
          "realName": {
            "type": "string",
            "description": "真实姓名",
            "example": "张三",
            "maxLength": 100
          },
          "deptId": {
            "type": "string",
            "description": "部门 ID",
            "format": "uuid"
          },
          "roleIds": {
            "type": "array",
            "description": "角色 ID 列表",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        "description": "创建用户请求"
      },
      "SysUserUpdateRequest": {
        "type": "object",
        "properties": {
          "realName": {
            "type": "string",
            "description": "真实姓名",
            "example": "张三",
            "maxLength": 100
          },
          "phone": {
            "type": "string",
            "description": "手机号",
            "example": "13800138000",
            "maxLength": 20
          },
          "email": {
            "type": "string",
            "description": "邮箱",
            "example": "demo@example.com",
            "maxLength": 100
          },
          "status": {
            "type": "integer",
            "description": "状态：1=启用，0=禁用",
            "format": "int32",
            "example": 1,
            "minimum": 0,
            "maximum": 1
          }
        },
        "description": "更新用户请求"
      },
      "SysUserResetPasswordRequest": {
        "required": ["newPassword"],
        "type": "object",
        "properties": {
          "newPassword": {
            "type": "string",
            "description": "新密码",
            "minLength": 6,
            "maxLength": 128
          }
        },
        "description": "重置密码请求"
      },
      "SysUserAssignRolesRequest": {
        "required": ["roleIds"],
        "type": "object",
        "properties": {
          "roleIds": {
            "type": "array",
            "description": "角色 ID 列表",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        "description": "分配角色请求"
      },
      "SysUserVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "用户 ID",
            "format": "uuid"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "realName": {
            "type": "string",
            "description": "真实姓名"
          },
          "phone": {
            "type": "string",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "description": "邮箱"
          },
          "deptId": {
            "type": "string",
            "description": "部门 ID",
            "format": "uuid"
          },
          "status": {
            "type": "integer",
            "description": "状态",
            "format": "int32"
          },
          "lastLoginAt": {
            "type": "string",
            "description": "最后登录时间",
            "format": "date-time"
          },
          "createTime": {
            "type": "string",
            "description": "创建时间",
            "format": "date-time"
          },
          "roleIds": {
            "type": "array",
            "description": "角色 ID 列表",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        "description": "用户视图对象"
      },
      "SysRoleCreateRequest": {
        "required": ["roleCode", "roleName"],
        "type": "object",
        "properties": {
          "roleCode": {
            "type": "string",
            "description": "角色编码",
            "example": "biz_staff",
            "maxLength": 50
          },
          "roleName": {
            "type": "string",
            "description": "角色名称",
            "example": "招商专员",
            "maxLength": 100
          },
          "dataScope": {
            "type": "integer",
            "description": "数据范围：1=本人，2=本组，3=全部",
            "format": "int32",
            "example": 1,
            "minimum": 1,
            "maximum": 3
          },
          "status": {
            "type": "integer",
            "description": "状态：1=启用，0=禁用",
            "format": "int32",
            "example": 1,
            "minimum": 0,
            "maximum": 1
          },
          "remark": {
            "type": "string",
            "description": "备注",
            "maxLength": 255
          }
        },
        "description": "创建角色请求"
      },
      "SysRoleUpdateRequest": {
        "required": ["roleCode", "roleName"],
        "type": "object",
        "properties": {
          "roleCode": {
            "type": "string",
            "description": "角色编码",
            "example": "biz_staff",
            "maxLength": 50
          },
          "roleName": {
            "type": "string",
            "description": "角色名称",
            "example": "招商专员",
            "maxLength": 100
          },
          "dataScope": {
            "type": "integer",
            "description": "数据范围：1=本人，2=本组，3=全部",
            "format": "int32",
            "example": 1,
            "minimum": 1,
            "maximum": 3
          },
          "status": {
            "type": "integer",
            "description": "状态：1=启用，0=禁用",
            "format": "int32",
            "example": 1,
            "minimum": 0,
            "maximum": 1
          },
          "remark": {
            "type": "string",
            "description": "备注",
            "maxLength": 255
          }
        },
        "description": "更新角色请求"
      },
      "SysRoleVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "角色 ID",
            "format": "uuid"
          },
