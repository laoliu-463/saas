# ============================================================
# Development image: hot-reload via volume mount
# Usage: docker compose up backend
#   - Mount backend/src as volume for source code hot-reload
#   - Spring Boot DevTools auto-restarts on classpath changes
# ============================================================
FROM eclipse-temurin:17-jdk-alpine

RUN apk add --no-cache maven bash findutils coreutils

WORKDIR /app

# Use shell entrypoint so JAVA_OPTS env can be expanded.
# /app is bind-mounted from host by docker-compose for hot-reload.
ENTRYPOINT ["sh", "-c", "sh /app/scripts/dev-hot-reload.sh"]

EXPOSE 8080 5005
