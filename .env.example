DOUYIN_TEST_ENABLED=true
DOUYIN_APP_ID=replace-with-test-app-id
DOUYIN_CLIENT_KEY=replace-with-test-client-key
DOUYIN_CLIENT_SECRET=replace-with-test-client-secret
