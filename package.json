{
  "name": "colonel-saas-e2e",
  "private": true,
  "scripts": {
    "start:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-test.ps1",
    "start:real-pre": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-real-pre.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "build": "npm --prefix frontend run build",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=chromium",
    "e2e:v1-p0": "playwright test --project=v1-p0",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:trace": "playwright test --trace on",
    "e2e:report": "playwright show-report",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:real-pre:preflight": "node runtime/qa/real-pre-preflight.cjs",
    "e2e:real-pre": "node runtime/qa/real-pre-douyin-frontend-e2e.cjs",
    "e2e:real-pre:business": "node runtime/qa/real-pre-business-e2e.cjs",
    "e2e:real-pre:roles": "node runtime/qa/real-pre-role-business-e2e.cjs",
    "e2e:real-pre:visual": "node runtime/qa/real-pre-visual-regression.cjs",
    "e2e:real-pre:journey:visual": "node runtime/qa/real-pre-full-business-journey.visual.cjs",
    "e2e:real-pre:all": "node runtime/qa/real-pre-all.cjs",
    "e2e:real-pre:p0:preflight": "node runtime/qa/real-pre-preflight.cjs",
    "e2e:real-pre:p0": "node runtime/qa/real-pre-p0.cjs",
    "e2e:real-pre:p0:headed": "node runtime/qa/real-pre-p0.cjs --headed --workers=1 --trace on --video on --screenshot on",
    "e2e:real-pre:dashboard-reconcile": "node runtime/qa/real-pre-dashboard-reconcile.cjs",
    "qa:real-pre:journey:visual": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/run-real-pre-full-business-journey-visual.ps1",
    "e2e:journey": "node runtime/qa/real-pre-journey-e2e.cjs",
    "qa:baiying:talents": "node runtime/qa/baiying-talent-collect.cjs",
    "test:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-all-tests.ps1",
    "test:frontend": "npm --prefix frontend run test",
    "test:frontend:coverage": "npm --prefix frontend run test:coverage",
    "api:cli:export-assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-api-cli-skill-assets.ps1",
    "apifox:verify": "bash scripts/verify-openapi-apifox.sh",
    "apifox:sync": "bash scripts/sync-apifox.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "dotenv": "^17.2.3"
  }
}
