{
  "name": "colonel-saas-e2e",
  "private": true,
  "scripts": {
    "build": "npm --prefix frontend run build",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:trace": "playwright test --trace on",
    "e2e:report": "playwright show-report",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:real-pre": "node runtime/qa/real-pre-douyin-frontend-e2e.cjs",
    "e2e:real-pre:business": "node runtime/qa/real-pre-business-e2e.cjs",
    "e2e:real-pre:roles": "node runtime/qa/real-pre-role-business-e2e.cjs",
    "e2e:real-pre:visual": "node runtime/qa/real-pre-visual-regression.cjs",
    "e2e:real-pre:journey:visual": "node runtime/qa/real-pre-full-business-journey.visual.cjs",
    "qa:real-pre:journey:visual": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/qa/run-real-pre-full-business-journey-visual.ps1",
    "e2e:journey": "cross-env E2E_REAL_PRE=true E2E_BASE_URL=http://localhost:3000 E2E_BACKEND_URL=http://localhost:8080 npx playwright test --project=full-journey"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "dotenv": "^17.2.3"
  }
}
